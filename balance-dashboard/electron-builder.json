{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.balance.industrial-weighing-dashboard",
  "productName": "Industrial Weighing Dashboard",
  "asar": true,
  "directories": {
    "output": "dist"
  },
  "files": [
    "dist-electron/**",
    "dist/**"
  ],
  "extraResources": [
    {
      "from": "../balences.ini",
      "to": "balences.ini"
    },
    {
      "from": "../install.bat",
      "to": "install.bat"
    },
    {
      "from": "../BalanceAgentService.exe",
      "to": "BalanceAgentService.exe"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "msi",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}_${version}.${ext}",
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "allowElevation": true,
    "include": "build/installer.nsh",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "menuCategory": "Industrial Weighing Dashboard"
  },
  "msi": {
    "createDesktopShortcut": true,
    "warningsAsErrors": false
  },
  "publish": [
    {
      "provider": "github",
      "owner": "RidaGrimmer",
      "repo": "BalanceAgentDashboard"
    }
  ]
}
